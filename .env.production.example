# Production Environment Configuration
# Copy this file to .env.production and fill in your values

# ============================================================================
# APPLICATION CONFIGURATION
# ============================================================================
ENVIRONMENT=production
DEBUG=false
APP_NAME="Prompt Optimization Platform"
WORKERS=4

# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================
POSTGRES_DB=prompt_optimization
POSTGRES_USER=prompt_user
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD_HERE
DATABASE_URL=postgresql://prompt_user:CHANGE_ME_STRONG_PASSWORD_HERE@postgres:5432/prompt_optimization

# ============================================================================
# REDIS CACHING & MESSAGE BROKER
# ============================================================================
REDIS_PASSWORD=redis_secure_password_here
REDIS_URL=redis://:redis_secure_password_here@redis:6379/0
CACHE_TTL=3600

# ============================================================================
# OPENAI API
# ============================================================================
OPENAI_API_KEY=sk-YOUR_OPENAI_API_KEY_HERE
OPENAI_MODEL=gpt-3.5-turbo
OPENAI_TIMEOUT=30

# ============================================================================
# SECURITY
# ============================================================================
SECRET_KEY=your-super-secret-key-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ============================================================================
# CORS & ALLOWED ORIGINS
# ============================================================================
ALLOWED_ORIGINS=https://yourdomain.com,https://app.yourdomain.com

# ============================================================================
# FRONTEND CONFIGURATION
# ============================================================================
NEXT_PUBLIC_API_URL=https://api.yourdomain.com
NODE_ENV=production

# ============================================================================
# CELERY ASYNC TASKS
# ============================================================================
CELERY_BROKER_URL=redis://:redis_secure_password_here@redis:6379/1
CELERY_RESULT_BACKEND=redis://:redis_secure_password_here@redis:6379/2

# ============================================================================
# LOGGING & MONITORING
# ============================================================================
LOG_LEVEL=INFO
LOG_FORMAT=json
ENABLE_PROMETHEUS=true
PROMETHEUS_PORT=8001

# ============================================================================
# OPTIMIZATION SETTINGS
# ============================================================================
MAX_ITERATIONS=10
VARIATIONS_PER_ITERATION=3
TIMEOUT_SECONDS=300

# ============================================================================
# OPTIONAL: MONITORING & ERROR TRACKING
# ============================================================================
# SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id
# DATADOG_API_KEY=your_datadog_api_key
